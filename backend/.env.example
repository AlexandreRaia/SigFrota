# ── Aplicação ──────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Banco de Dados ──────────────────────────────────────────
POSTGRES_DB=sigfrota
POSTGRES_USER=sigfrota
POSTGRES_PASSWORD=sigfrota_dev
DATABASE_URL=postgresql+asyncpg://sigfrota:sigfrota_dev@localhost:5432/sigfrota

# ── Segurança ───────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-string-aleatoria-de-64-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Arquivos de Mídia ───────────────────────────────────────
MEDIA_DIR=media
MAX_UPLOAD_SIZE_MB=10
