# SisGestaoFrota — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# ----------------------------------------------------------------
# Django
# ----------------------------------------------------------------
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------
# Banco de dados
# development: deixe em branco (usa SQLite3 automaticamente)
# production:  defina a URL do PostgreSQL abaixo
# ----------------------------------------------------------------
DATABASE_URL=postgres://usuario:senha@localhost:5432/sigfrota

# ----------------------------------------------------------------
# E-mail (SMTP)
# ----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=noreply@santanadeparnaiba.sp.gov.br
